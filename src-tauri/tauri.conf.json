{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NovaMind AI",
  "version": "0.1.0",
  "identifier": "com.novamind.ai",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "NovaMind AI",
        "width": 1180,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "shortDescription": "A compact AI desktop chat companion.",
    "longDescription": "NovaMind AI is a compact desktop assistant built around a focused chat workspace with screen capture, document uploads, and voice input."
  }
}
